   (let* (
      ($_1 (println! "| Concept | Via Feature | To Action | calculation |"))
      ($_2 (println! "| :--- | :--- | :--- | :--- |"))
      ; Cup
      ($_3 (print-trace-row Cup containsLiquid measureWater200ml))
      ($_4 (print-trace-row Cup hasVolumeMarks measureWater200ml))
      ($_5 (print-trace-row Cup pourable measureWater200ml))
      ($_6 (print-trace-row Cup handheld measureWater200ml))
      ($_7 (print-trace-row Cup containsLiquid transferWaterToBowl))
      ($_8 (print-trace-row Cup hasVolumeMarks transferWaterToBowl))
      ($_9 (print-trace-row Cup pourable transferWaterToBowl))
      ($_10 (print-trace-row Cup handheld transferWaterToBowl))
      ; MeasuringTool
      ($_11 (print-trace-row MeasuringTool containsLiquid measureWater200ml))
      ($_12 (print-trace-row MeasuringTool hasVolumeMarks measureWater200ml))
      ($_13 (print-trace-row MeasuringTool pourable measureWater200ml))
      ($_14 (print-trace-row MeasuringTool handheld measureWater200ml))
      ($_15 (print-trace-row MeasuringTool containsLiquid transferWaterToBowl))
      ($_16 (print-trace-row MeasuringTool hasVolumeMarks transferWaterToBowl))
      ($_17 (print-trace-row MeasuringTool pourable transferWaterToBowl))
      ($_18 (print-trace-row MeasuringTool handheld transferWaterToBowl))
      ; Bowl
      ($_19 (print-trace-row Bowl containsLiquid measureWater200ml))
      ($_20 (print-trace-row Bowl hasVolumeMarks measureWater200ml))
      ($_21 (print-trace-row Bowl pourable measureWater200ml))
      ($_22 (print-trace-row Bowl handheld measureWater200ml))
      ($_23 (print-trace-row Bowl containsLiquid transferWaterToBowl))
      ($_24 (print-trace-row Bowl hasVolumeMarks transferWaterToBowl))
      ($_25 (print-trace-row Bowl pourable transferWaterToBowl))
