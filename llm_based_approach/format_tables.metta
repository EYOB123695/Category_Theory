   )
)

(= (print-support-summary-row $concept)
   (let* (
      ($sup-m (composed-support $concept measureWater200ml))
      ($sup-t (composed-support $concept transferWaterToBowl))
      ($r1 (concat-str "| **" $concept))
      ($r2 (concat-str $r1 "** | "))
      ($r3 (concat-str $r2 $sup-m))
      ($r4 (concat-str $r3 " | "))
      ($r5 (concat-str $r4 $sup-t))
      ($row (concat-str $r5 " |"))
   )
   (println! $row)
   )
)

(= (print-support-summary-table)
   (let* (
      ($_1 (println! "| Concept | Support Measure | Support Transfer |"))
      ($_2 (println! "| :--- | :---: | :---: |"))
      ($_3 (print-support-summary-row Cup))
      ($_4 (print-support-summary-row MeasuringTool))
      ($_5 (print-support-summary-row Bowl))
      ($_6 (print-support-summary-row MeasuringCup))
   )
   ()
   )
)

(= (print-blend-row $concept)
   (let* (
      ($liquid (* 1.0 (hasFeature $concept containsLiquid)))
      ($marks  (* 1.0 (hasFeature $concept hasVolumeMarks)))
      ($quality (* $liquid $marks))
      ($r1 (concat-str "| **" $concept))
      ($r2 (concat-str $r1 "** | "))
      ($r3 (concat-str $r2 $liquid))
      ($r4 (concat-str $r3 " | "))
      ($r5 (concat-str $r4 $marks))
      ($r6 (concat-str $r5 " | **"))
      ($r7 (concat-str $r6 $quality))
      ($row (concat-str $r7 "** |"))
   )
   (println! $row)
   )
)

(= (print-blend-verification-table)
   (let* (
      ($_1 (println! "| Concept | liquid | marks | Blend Quality |"))
      ($_2 (println! "| :--- | :---: | :---: | :---: |"))
      ($_3 (print-blend-row Cup))
      ($_4 (print-blend-row MeasuringTool))
      ($_5 (print-blend-row Bowl))
      ($_6 (print-blend-row MeasuringCup))
   )
   ()
   )
)

(= (print-inheritance-row $feature)
   (let* (
      ($blend (hasFeature MeasuringCup $feature))
      ($cup   (hasFeature Cup $feature))
      ($tool  (hasFeature MeasuringTool $feature))
      ($r1 (concat-str "| " $feature))
      ($r2 (concat-str $r1 " | **"))
      ($r3 (concat-str $r2 $blend))
      ($r4 (concat-str $r3 "** | "))
      ($r5 (concat-str $r4 $cup))
      ($r6 (concat-str $r5 " | "))
      ($r7 (concat-str $r6 $tool))
      ($row (concat-str $r7 " |"))
   )
   (println! $row)
   )
)

(= (print-blend-inheritance-table)
   (let* (
      ($_1 (println! "| Feature | MeasuringCup (Blend) | Cup (Source) | MeasuringTool (Source) |"))
      ($_2 (println! "| :--- | :---: | :---: | :---: |"))
      ($_3 (print-inheritance-row containsLiquid))
      ($_4 (print-inheritance-row hasVolumeMarks))
      ($_5 (print-inheritance-row pourable))
      ($_6 (print-inheritance-row handheld))
   )
   ()
   )
)

(= (print-comparison-row $concept)
   (let* (
      ($s-measure (affords $concept measureWater200ml))
      ($s-pour    (affords $concept transferWaterToBowl))
      ($direct (* $s-measure $s-pour))
      
      ($comp-measure (composed-support $concept measureWater200ml))
      ($comp-pour    (composed-support $concept transferWaterToBowl))
      ($composed (* $comp-measure $comp-pour))
      
      ($r1 (concat-str "| **" $concept))
      ($r2 (concat-str $r1 "** | "))
      ($r3 (concat-str $r2 $direct))
      ($r4 (concat-str $r3 " | **"))
      ($r5 (concat-str $r4 $composed))
      ($row (concat-str $r5 "** |"))
   )
   (println! $row)
   )
)

(= (print-final-comparison-table)
   (let* (
      ($_1 (println! "| Concept | Direct Score | Composed Score |"))
      ($_2 (println! "| :--- | :---: | :---: |"))
      ($_3 (print-comparison-row Cup))
      ($_4 (print-comparison-row MeasuringTool))
      ($_5 (print-comparison-row Bowl))
      ($_6 (print-comparison-row MeasuringCup))
   )
   ()
   )
)

; ============================================================================
; 3. EXECUTION & TRACE GENERATION
; ============================================================================

!(println! "")
!(println! "PHASE 1: CONCEPT x FEATURE TABLE")
!(print-features-table)

!(println! "")
!(println! "PHASE 2: CONCEPT x ACTION TABLE")
!(print-affordances-table)

!(println! "")
!(println! "PHASE 3: PROFUNCTOR ALIGNMENT MATRIX")
!(print-profunctors-table)

!(println! "")
!(println! "PHASE 4: SEMANTIC AXIOM VERIFICATION")
!(print-axioms-table)

!(println! "")
!(println! "PHASE 5: DIRECT AFFORDANCE SCORING")
!(print-direct-scores-table)

!(println! "")
!(println! "PHASE 6: MAX-PRODUCT COMPOSED SCORING")
!(print-composed-scores-table)

!(println! "")
!(println! "PHASE 7: DETAILED MAX-PRODUCT TRACE (MeasuringCup)")
!(print-trace-table-measuringcup)
!(println! "Composed support summary:")
!(print-support-summary-table)

!(println! "")
!(println! "PHASE 8: FULL COMPOSITION TRACE (All Concepts)")
!(print-trace-table-all)

!(println! "")
!(println! "PHASE 9: PUSHOUT BLEND VERIFICATION & FEATURE INHERITANCE")
!(print-blend-verification-table)
!(println! "")
!(print-blend-inheritance-table)

!(println! "")
!(println! "PHASE 10: FINAL COMPARISON & WINNER DETERMINATION")
!(print-final-comparison-table)

!(println! "")
!(println! "REASONING EXPLANATION & WINNER:")
!(println! "MeasuringCup is the optimal choice for the instruction because it preserves both required roles.")
!(println! "It contains/pours liquid like a Cup, and measures volume like a MeasuringTool.")
!(println! "Alternatives lose support on one of the required actions (Cup fails at measuring, MeasuringTool fails at transferring).")
